{
  "name": "@theluckystrike/webext-context-menu",
  "version": "1.0.0",
  "description": "Typed context menu builder with nested menus and fluent API for Chrome extensions. Part of @zovo/webext.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theluckystrike/webext-context-menu.git"
  },
  "homepage": "https://github.com/theluckystrike/webext-context-menu#readme",
  "bugs": {
    "url": "https://github.com/theluckystrike/webext-context-menu/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepare": "npm run build"
  },
  "keywords": [
    "chrome-extension",
    "context-menu",
    "webextension",
    "typescript"
  ],
  "author": "theluckystrike",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
